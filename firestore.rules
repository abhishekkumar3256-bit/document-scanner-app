rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // User Profile Rules
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid == request.auth.uid &&
               data.email is string &&
               data.createdAt is timestamp;
      }
      
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt']);
    }

    // Document Metadata Rules
    match /documents/{docId} {
      function isValidDocument(data) {
        return data.userId == request.auth.uid &&
               data.title is string && data.title.size() <= 100 &&
               data.localFileKey is string &&
               data.createdAt is timestamp;
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidDocument(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isOwner(existing().userId) && isValidDocument(incoming()) &&
                    incoming().id == existing().id &&
                    incoming().userId == existing().userId &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time &&
                    incoming().diff(existing()).affectedKeys().hasAny(['title', 'description', 'aiSummary', 'tags', 'updatedAt']);
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }
  }
}
