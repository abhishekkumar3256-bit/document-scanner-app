{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile data including preferences and settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Document": {
      "title": "Scanned Document",
      "description": "Metadata for a scanned document. Actual files are stored in IndexedDB via localforage for offline access.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["pdf", "jpg", "png", "docx", "xlsx"] },
        "size": { "type": "number" },
        "localFileKey": { "type": "string", "description": "Key to retrieve the blob from localforage" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "aiSummary": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "userId", "title", "createdAt", "localFileKey"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Stores user profile information."
    },
    "/documents/{docId}": {
      "schema": "Document",
      "description": "Stores document metadata."
    }
  }
}
